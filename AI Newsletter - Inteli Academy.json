    {
      "parameters": {
        "jsCode": "// Puxa o item consolidado do nó Merge\nconst input = $input.all()[0].json;\n\nlet outputText = \"\";\nlet globalIndex = 0;\n\n// Função padronizada para montar o texto exatamente no seu formato\nfunction addNews(source, title, summary, url) {\n  // Só adiciona se tiver título e link\n  if (title && url) {\n    // Limpa quebras de linha que possam bagunçar o texto\n    let cleanSummary = (summary || '').replace(/\\n/g, ' ').trim();\n    \n    outputText += `${globalIndex}\\n`;\n    outputText += `source:${source}\\n`;\n    outputText += `title:${title}\\n`;\n    outputText += `summary:${cleanSummary}\\n`;\n    outputText += `url:${url}\\n\\n`;\n    \n    globalIndex++;\n  }\n}\n\n// 1. Processar NewsAPI (BR) -> Usando o nome correto: articles_PtBr\nif (input.articles_PtBr && Array.isArray(input.articles_PtBr)) {\n  // Pegando as 5 primeiras notícias (pode alterar o .slice se quiser mais ou menos)\n  input.articles_PtBr.slice(0, 5).forEach(a => addNews(\"NewsAPI (BR)\", a.title, a.description, a.url));\n}\n\n// 2. Processar NewsAPI (USA) -> Usando o nome correto: articles_Geral\nif (input.articles_Geral && Array.isArray(input.articles_Geral)) {\n  input.articles_Geral.slice(0, 5).forEach(a => addNews(\"NewsAPI (USA)\", a.title, a.description, a.url));\n}\n\n// 3. Processar Dev.to -> Usando o nome correto: dev_to_items\nif (input.dev_to_items && Array.isArray(input.dev_to_items)) {\n  input.dev_to_items.slice(0, 5).forEach(a => addNews(\"Dev.to\", a.title, a.description, a.url));\n}\n\n// 4. Processar arXiv (Papers) -> Usando o nome correto: feed.entry\nif (input.feed && input.feed.entry && Array.isArray(input.feed.entry)) {\n  // No arXiv, o resumo chama 'summary' e o link chama 'id'\n  input.feed.entry.slice(0, 5).forEach(a => addNews(\"arXiv\", a.title, a.summary, a.id));\n}\n\n// 5. Processar Tavily Search -> Usando o nome correto: results\nif (input.results && Array.isArray(input.results)) {\n  // No Tavily, o resumo chama 'content'\n  input.results.slice(0, 5).forEach(a => addNews(\"Tavily\", a.title, a.content, a.url));\n}\n\n// Retorna o super bloco de texto formatado para o próximo nó\nreturn [{ \n  json: { \n    resultado_formatado: outputText.trim() \n  } \n}];"
      },
